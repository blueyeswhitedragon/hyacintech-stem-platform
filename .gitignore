# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma / sqlite
/prisma/dev.db
/prisma/dev.db-journal
*.db
*.db-journal

# uploaded files (keep the dir, ignore contents)
/public/uploads/*
!/public/uploads/.gitkeep

# local operational backups
/backups/
/logs/
/tmp/
/data/sft/v3/runs/*/run.lock

# local source captures and incomplete external downloads
/basic.smartedu.cn.har
/aTrustInstaller_amd64.rpm
/Magpie-Qwen2-Pro-200K-Chinese/
