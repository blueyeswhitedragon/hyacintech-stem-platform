// Hyacintech STEM 平台 · 数据库模型
// 按「框架2(1).txt」第三章定义；SQLite + Prisma。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(uuid())
  username       String    @unique
  passwordHash   String
  role           String // "student" | "teacher" | "annotator" | "reviewer" | "admin"
  displayName    String
  isActive       Boolean   @default(true)
  sessionVersion Int       @default(0)
  disabledAt     DateTime?
  disabledReason String    @default("")
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  ownedClasses       Class[]             @relation("TeacherClasses")
  classMemberships   ClassMember[]
  studentAssignments StudentAssignment[]
  conversations      Conversation[]

  importedDatasetBatches DatasetBatch[]         @relation("DatasetBatchImporter")
  createdCampaigns       AnnotationCampaign[]   @relation("CampaignCreator")
  campaignParticipations CampaignParticipant[]
  annotationTasks        AnnotationTask[]       @relation("TaskAssignee")
  annotationRevisions    AnnotationRevision[]   @relation("RevisionAuthor")
  completedWorkReviews   AnnotationWorkReview[] @relation("WorkReviewReviewer")
  assignedReviewCases    ReviewCase[]           @relation("ReviewCaseAssignee")
  reviewDecisions        ReviewDecision[]       @relation("DecisionReviewer")
  createdDatasetReleases DatasetRelease[]       @relation("ReleaseCreator")
  createdTrainingRuns    TrainingRun[]          @relation("TrainingRunCreator")
  createdEvaluationRuns  EvaluationRun[]        @relation("EvaluationRunCreator")
  createdModelVersions   ModelVersion[]         @relation("ModelVersionCreator")
  createdDeployments     ModelDeployment[]      @relation("ModelDeploymentCreator")
  nominatedCandidates    ProductionCandidate[]  @relation("CandidateNominator")
  processedCandidates    ProductionCandidate[]  @relation("CandidateProcessor")
  dataLabAuditLogs       DataLabAuditLog[]      @relation("AuditActor")

  createdTopicCards      TopicCard[]              @relation("TopicCardCreator")
  approvedTopicCards     TopicCard[]              @relation("TopicCardApprover")
  createdTopicSources    TopicSourceCandidate[]    @relation("TopicSourceCreator")
  createdBootstrapRuns   BootstrapGenerationRun[] @relation("BootstrapRunCreator")
  assignedTutorReviews   TutorReviewTask[]        @relation("TutorReviewAssignee")
  operatedTutorReviews   TutorReviewTask[]        @relation("TutorReviewOperator")
  finalizedFirstReviews  FinalizedTutorTurn[]     @relation("FinalizedFirstReviewer")
  finalizedSecondReviews FinalizedTutorTurn[]     @relation("FinalizedSecondReviewer")

  @@index([role, isActive])
}

model Class {
  id         String   @id @default(uuid())
  name       String
  inviteCode String   @unique
  teacherId  String
  createdAt  DateTime @default(now())

  teacher     User          @relation("TeacherClasses", fields: [teacherId], references: [id])
  members     ClassMember[]
  assignments Assignment[]
}

model ClassMember {
  id        String   @id @default(uuid())
  classId   String
  studentId String
  joinedAt  DateTime @default(now())

  class   Class @relation(fields: [classId], references: [id])
  student User  @relation(fields: [studentId], references: [id])

  @@unique([classId, studentId])
}

model Assignment {
  id                   String    @id @default(uuid())
  classId              String
  title                String
  topicDirection       String? // 可选，限定阶段1的研究方向
  assistantStyleFamily String    @default("auto")
  stylePolicyVersion   String    @default("style-v1")
  dataContributionMode String    @default("DISABLED")
  dataPolicyVersion    String?
  dueDate              DateTime?
  createdAt            DateTime  @default(now())

  class              Class               @relation(fields: [classId], references: [id])
  studentAssignments StudentAssignment[]
}

model StudentAssignment {
  id                       String    @id @default(uuid())
  assignmentId             String
  studentId                String
  conversationId           String?   @unique // 一对一关联 Conversation
  status                   String    @default("NOT_STARTED")
  // 状态可选值: NOT_STARTED, IN_PROGRESS, PENDING_STAGE2, PENDING_STAGE5, COMPLETED
  currentStage             Int       @default(0) // 0-6
  dataConsentStatus        String    @default("NOT_APPLICABLE")
  dataConsentPolicyVersion String?
  dataConsentDecidedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignment   Assignment    @relation(fields: [assignmentId], references: [id])
  student      User          @relation(fields: [studentId], references: [id])
  conversation Conversation? @relation(fields: [conversationId], references: [id])

  @@unique([assignmentId, studentId]) // 同一作业对同一学生只允许一条
}

model Conversation {
  id     String @id @default(uuid())
  userId String

  messages               String  @default("[]") // JSON 数组，存储完整的对话历史
  stageData              String  @default("{}") // JSON 对象，存储所有阶段快照
  safetyQuizCompleted    Boolean @default(false) // 阶段3安全问答是否已完成（正式模式）
  resolvedStyleFamily    String  @default("classroom_coach")
  stylePolicyVersion     String  @default("style-v1")
  traceCoverage          String  @default("LEGACY_UNVERIFIED")
  deployedModelVersionId String?
  contractVersion        String  @default("stage-contract-v2")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                  User                   @relation(fields: [userId], references: [id])
  // 1:1 关系的外键持有方是 StudentAssignment.conversationId，此处为虚拟反向关系。
  // （框架2在两侧都写了外键，Prisma 不允许循环 1:1，故只在 StudentAssignment 侧保留 FK。）
  studentAssignment     StudentAssignment?
  generationTraces      GenerationTrace[]
  deployedModelVersion  ModelVersion?          @relation("ConversationDeployedModel", fields: [deployedModelVersionId], references: [id], onDelete: SetNull)
  stateExtractionTraces StateExtractionTrace[]
}

model DatasetBatch {
  id             String   @id @default(uuid())
  name           String   @unique
  sourceType     String
  sourceFileName String
  sourceSha256   String   @unique
  status         String   @default("IMPORTED")
  manifestJson   String   @default("{}")
  summaryJson    String   @default("{}")
  importedById   String
  importedAt     DateTime @default(now())

  importedBy User            @relation("DatasetBatchImporter", fields: [importedById], references: [id])
  samples    DatasetSample[]
}

model DatasetSample {
  id                 String   @id @default(uuid())
  batchId            String
  sourceRecordId     String   @unique
  familyKey          String
  phase              Int
  scenario           String
  sourceKind         String
  candidateTier      String
  rubricTargetsJson  String   @default("[]")
  autoCheckJson      String   @default("{}")
  originalRecordJson String
  createdAt          DateTime @default(now())

  batch               DatasetBatch         @relation(fields: [batchId], references: [id], onDelete: Cascade)
  tasks               AnnotationTask[]
  revisions           AnnotationRevision[]
  reviewCases         ReviewCase[]
  releaseItems        DatasetReleaseItem[]
  productionCandidate ProductionCandidate?

  @@index([phase])
  @@index([candidateTier])
  @@index([familyKey])
}

model AnnotationCampaign {
  id                        String    @id @default(uuid())
  name                      String    @unique
  status                    String    @default("DRAFT")
  selectionJson             String    @default("{}")
  protocol                  String    @default("GOLD_DOUBLE_SILVER_SINGLE")
  styleQuotaJson            String    @default("{}")
  stylePolicyVersion        String    @default("style-v1")
  goldSlots                 Int       @default(2)
  silverDoubleReviewPercent Int       @default(30)
  maxActivePerAnnotator     Int       @default(1)
  createdById               String
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  startedAt                 DateTime?
  completedAt               DateTime?

  createdBy    User                  @relation("CampaignCreator", fields: [createdById], references: [id])
  tasks        AnnotationTask[]
  participants CampaignParticipant[]
  reviewCases  ReviewCase[]
  releases     DatasetRelease[]
}

model CampaignParticipant {
  id         String   @id @default(uuid())
  campaignId String
  userId     String
  taskLimit  Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  campaign AnnotationCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@index([userId, active])
}

model AnnotationTask {
  id                 String    @id @default(uuid())
  campaignId         String
  sampleId           String
  slot               Int
  styleFamily        String?
  stylePolicyVersion String    @default("style-v1")
  status             String    @default("PENDING")
  assignedToId       String?
  draftJson          String    @default("{}")
  leaseExpiresAt     DateTime?
  submittedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  campaign    AnnotationCampaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sample      DatasetSample          @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  assignedTo  User?                  @relation("TaskAssignee", fields: [assignedToId], references: [id])
  revisions   AnnotationRevision[]
  workReviews AnnotationWorkReview[]

  @@unique([campaignId, sampleId, slot])
  @@index([campaignId, status])
  @@index([assignedToId, status])
}

model AnnotationRevision {
  id                        String   @id @default(uuid())
  taskId                    String
  sampleId                  String
  authorId                  String
  version                   Int
  contentJson               String
  fullRecordJson            String
  issueTagsJson             String   @default("[]")
  changeReason              String   @default("")
  noChange                  Boolean  @default(false)
  styleFamily               String?
  stylePolicyVersion        String?
  transformationType        String   @default("UNCLASSIFIED")
  transformationMetricsJson String   @default("{}")
  parentRevisionId          String?
  createdAt                 DateTime @default(now())

  task           AnnotationTask        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  sample         DatasetSample         @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  author         User                  @relation("RevisionAuthor", fields: [authorId], references: [id])
  parentRevision AnnotationRevision?   @relation("RevisionChain", fields: [parentRevisionId], references: [id], onDelete: SetNull)
  childRevisions AnnotationRevision[]  @relation("RevisionChain")
  selectedBy     ReviewDecision[]      @relation("SelectedRevision")
  mergedBy       ReviewDecision[]      @relation("MergedRevision")
  releaseItems   DatasetReleaseItem[]
  workReview     AnnotationWorkReview?

  @@unique([taskId, version])
  @@index([sampleId])
}

model AnnotationWorkReview {
  id         String    @id @default(uuid())
  taskId     String
  revisionId String    @unique
  status     String    @default("PENDING")
  note       String    @default("")
  reviewerId String?
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  task     AnnotationTask     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  revision AnnotationRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  reviewer User?              @relation("WorkReviewReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([taskId, status])
  @@index([reviewerId])
}

model ReviewCase {
  id                       String    @id @default(uuid())
  campaignId               String
  sampleId                 String
  triggerReason            String
  candidateRevisionIdsJson String    @default("[]")
  status                   String    @default("PENDING")
  assignedReviewerId       String?
  assignedAt               DateTime?
  decidedAt                DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  campaign         AnnotationCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sample           DatasetSample      @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  assignedReviewer User?              @relation("ReviewCaseAssignee", fields: [assignedReviewerId], references: [id])
  decision         ReviewDecision?

  @@unique([campaignId, sampleId])
  @@index([status])
}

model ReviewDecision {
  id                 String   @id @default(uuid())
  reviewCaseId       String   @unique
  reviewerId         String
  action             String
  selectedRevisionId String?
  mergedRevisionId   String?
  finalTier          String
  rubricJson         String   @default("{}")
  reason             String   @default("")
  createdAt          DateTime @default(now())

  reviewCase       ReviewCase          @relation(fields: [reviewCaseId], references: [id], onDelete: Cascade)
  reviewer         User                @relation("DecisionReviewer", fields: [reviewerId], references: [id])
  selectedRevision AnnotationRevision? @relation("SelectedRevision", fields: [selectedRevisionId], references: [id], onDelete: SetNull)
  mergedRevision   AnnotationRevision? @relation("MergedRevision", fields: [mergedRevisionId], references: [id], onDelete: SetNull)
}

model DatasetRelease {
  id                    String    @id @default(uuid())
  version               String    @unique
  status                String    @default("DRAFT")
  campaignId            String?
  recipeJson            String    @default("{}")
  summaryJson           String    @default("{}")
  cleanPath             String?
  cleanSha256           String?
  goldPath              String?
  goldSha256            String?
  silverPath            String?
  silverSha256          String?
  trainingPath          String?
  trainingSha256        String?
  preferencePath        String?
  preferenceSha256      String?
  eligibilityReportJson String    @default("{}")
  manifestPath          String?
  manifestSha256        String?
  createdById           String
  createdAt             DateTime  @default(now())
  frozenAt              DateTime?

  campaign     AnnotationCampaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  createdBy    User                 @relation("ReleaseCreator", fields: [createdById], references: [id])
  items        DatasetReleaseItem[]
  trainingRuns TrainingRun[]
}

model DatasetReleaseItem {
  id                    String   @id @default(uuid())
  releaseId             String
  sampleId              String?
  finalizedTutorTurnId  String?
  revisionId            String?
  tier                  String
  weight                Float    @default(1)
  inclusionReason       String
  recordJson            String
  styleFamily           String?
  stylePolicyVersion    String?
  trainingEligibility   String   @default("SFT_ALLOWED")
  eligibilityReasonJson String   @default("[]")
  createdAt             DateTime @default(now())

  release            DatasetRelease      @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  sample             DatasetSample?      @relation(fields: [sampleId], references: [id])
  finalizedTutorTurn FinalizedTutorTurn? @relation(fields: [finalizedTutorTurnId], references: [id])
  revision           AnnotationRevision? @relation(fields: [revisionId], references: [id], onDelete: SetNull)

  @@unique([releaseId, sampleId])
  @@unique([releaseId, finalizedTutorTurnId])
  @@index([tier])
}

model TrainingRun {
  id                    String   @id @default(uuid())
  name                  String   @unique
  releaseId             String
  baseModel             String
  externalTaskId        String?
  parametersJson        String   @default("{}")
  status                String   @default("DRAFT")
  modelTag              String?
  parentModelVersionId  String?
  eligibilityReportJson String   @default("{}")
  policyVersion         String   @default("training-policy-v1")
  notes                 String   @default("")
  createdById           String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  release            DatasetRelease @relation(fields: [releaseId], references: [id])
  createdBy          User           @relation("TrainingRunCreator", fields: [createdById], references: [id])
  outputModelVersion ModelVersion?
  parentModelVersion ModelVersion?  @relation("TrainingParent", fields: [parentModelVersionId], references: [id], onDelete: SetNull)
}

model EvaluationRun {
  id                 String   @id @default(uuid())
  name               String   @unique
  status             String   @default("IMPORTED")
  modelATag          String
  modelBTag          String
  scope              String
  summaryJson        String   @default("{}")
  styleFamily        String?
  stylePolicyVersion String?
  modelAVersionId    String?
  modelBVersionId    String?
  gateResult         String   @default("NOT_EVALUATED")
  gateReportJson     String   @default("{}")
  createdById        String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  createdBy     User                 @relation("EvaluationRunCreator", fields: [createdById], references: [id])
  artifacts     EvaluationArtifact[]
  deployments   ModelDeployment[]
  modelAVersion ModelVersion?        @relation("EvaluationModelA", fields: [modelAVersionId], references: [id], onDelete: SetNull)
  modelBVersion ModelVersion?        @relation("EvaluationModelB", fields: [modelBVersionId], references: [id], onDelete: SetNull)
}

model ModelVersion {
  id                   String   @id @default(uuid())
  tag                  String   @unique
  provider             String
  externalModelId      String
  parentModelVersionId String?
  trainingRunId        String?  @unique
  promptPolicyVersion  String   @default("stem-six-phase-v2")
  contractVersion      String   @default("stage-contract-v2")
  status               String   @default("DRAFT")
  createdById          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  parent                ModelVersion?     @relation("ModelLineage", fields: [parentModelVersionId], references: [id], onDelete: SetNull)
  children              ModelVersion[]    @relation("ModelLineage")
  trainingRun           TrainingRun?      @relation(fields: [trainingRunId], references: [id], onDelete: SetNull)
  createdBy             User?             @relation("ModelVersionCreator", fields: [createdById], references: [id], onDelete: SetNull)
  generationTraces      GenerationTrace[]
  deployments           ModelDeployment[] @relation("DeploymentModel")
  previousDeployments   ModelDeployment[] @relation("PreviousDeploymentModel")
  childTrainingRuns     TrainingRun[]     @relation("TrainingParent")
  deployedConversations Conversation[]    @relation("ConversationDeployedModel")
  evaluationsAsA        EvaluationRun[]   @relation("EvaluationModelA")
  evaluationsAsB        EvaluationRun[]   @relation("EvaluationModelB")

  @@index([provider, externalModelId])
  @@index([parentModelVersionId])
  @@index([status])
}

model ModelDeployment {
  id                     String    @id @default(uuid())
  modelVersionId         String
  previousModelVersionId String?
  environment            String    @default("PRODUCTION")
  rolloutPercent         Int       @default(100)
  status                 String    @default("DRAFT")
  evaluationRunId        String?
  createdById            String?
  startedAt              DateTime?
  endedAt                DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  gateReportJson         String    @default("{}")
  observationJson        String    @default("{}")

  modelVersion         ModelVersion   @relation("DeploymentModel", fields: [modelVersionId], references: [id])
  previousModelVersion ModelVersion?  @relation("PreviousDeploymentModel", fields: [previousModelVersionId], references: [id], onDelete: SetNull)
  evaluationRun        EvaluationRun? @relation(fields: [evaluationRunId], references: [id], onDelete: SetNull)
  createdBy            User?          @relation("ModelDeploymentCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([environment, status])
  @@index([modelVersionId])
}

model GenerationTrace {
  id                           String   @id @default(uuid())
  conversationId               String
  assistantMessageId           String   @unique
  userMessageId                String
  triggerType                  String   @default("USER_MESSAGE")
  stage                        Int
  modelVersionId               String
  modelTagSnapshot             String
  providerSnapshot             String
  externalModelSnapshot        String
  promptVersion                String
  promptSha256                 String
  // Versioned prompt template only; rendered prompts may contain student data.
  systemPromptSnapshot         String   @default("")
  // Exact rendered prompt, captured only after explicit student data consent.
  trainingSystemPromptSnapshot String   @default("")
  styleFamily                  String
  stylePolicyVersion           String
  requestMessageSha256         String
  responseJson                 String
  responseSha256               String
  generationParamsJson         String   @default("{}")
  contractVersion              String
  contractCheckJson            String   @default("{}")
  createdAt                    DateTime @default(now())

  conversation        Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  modelVersion        ModelVersion         @relation(fields: [modelVersionId], references: [id])
  productionCandidate ProductionCandidate?

  @@index([conversationId, createdAt])
  @@index([modelVersionId, createdAt])
  @@index([stage])
  @@index([triggerType, createdAt])
}

model ProductionCandidate {
  id                       String    @id @default(uuid())
  generationTraceId        String    @unique
  status                   String    @default("NOMINATED")
  triggerType              String
  triggerNote              String    @default("")
  signalJson               String    @default("{}")
  consentStatusSnapshot    String
  dataPolicyVersion        String
  redactedRecordJson       String
  redactionReportJson      String    @default("{}")
  contentSha256            String
  familyKey                String
  leakageCheckJson         String    @default("{}")
  nominatedById            String?
  processedById            String?
  rejectionReason          String    @default("")
  convertedSampleId        String?   @unique
  convertedTutorTurnCaseId String?   @unique
  processedAt              DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  generationTrace        GenerationTrace @relation(fields: [generationTraceId], references: [id], onDelete: Cascade)
  nominatedBy            User?           @relation("CandidateNominator", fields: [nominatedById], references: [id], onDelete: SetNull)
  processedBy            User?           @relation("CandidateProcessor", fields: [processedById], references: [id], onDelete: SetNull)
  convertedSample        DatasetSample?  @relation(fields: [convertedSampleId], references: [id], onDelete: SetNull)
  convertedTutorTurnCase TutorTurnCase?  @relation(fields: [convertedTutorTurnCaseId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([contentSha256])
  @@index([familyKey])
}

model TopicSourceCandidate {
  id                  String   @id @default(uuid())
  sourceKey           String   @unique
  familyKey           String
  familyOverrideKey   String   @default("")
  title               String
  summary             String   @default("")
  resourceType        String   @default("UNCLASSIFIED")
  sourcePlatform      String
  sourceResourceId    String   @default("")
  sourceUrl           String   @default("")
  authorizationStatus String   @default("UNCONFIRMED")
  rawSourceJson       String   @default("{}")
  legacyHintsJson     String   @default("{}")
  qualitySignalsJson  String   @default("[]")
  status              String   @default("NEW")
  createdById         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  createdBy User?       @relation("TopicSourceCreator", fields: [createdById], references: [id], onDelete: SetNull)
  cards     TopicCard[]

  @@index([status, createdAt])
  @@index([familyKey])
  @@index([familyOverrideKey])
  @@index([authorizationStatus])
}

model TopicCard {
  id                       String    @id @default(uuid())
  displayTitle             String
  studentOpening           String
  internalArchetype        String
  subject                  String
  gradeBand                String
  coreMechanism            String
  acceptableDirectionsJson String    @default("[]")
  forbiddenDirectionsJson  String    @default("[]")
  curriculumAnchorsJson    String    @default("[]")
  sourceJson               String    @default("{}")
  compilerEvidenceJson     String    @default("{}")
  schemaVersion            Int       @default(1)
  revision                 Int       @default(1)
  revisionOfId             String?
  activityMode             String    @default("")
  contextModule            String    @default("")
  disciplineAnchorsJson    String    @default("[]")
  authenticNeed            String    @default("")
  stakeholder              String    @default("")
  engineeringGoal          String    @default("")
  constraintsJson          String    @default("[]")
  performanceCriteriaJson  String    @default("[]")
  inquiryBridgesJson       String    @default("[]")
  sourceCandidateId        String?
  status                   String    @default("DRAFT")
  rejectionReason          String    @default("")
  createdById              String?
  approvedById             String?
  approvedAt               DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  createdBy       User?                 @relation("TopicCardCreator", fields: [createdById], references: [id], onDelete: SetNull)
  approvedBy      User?                 @relation("TopicCardApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  revisionOf      TopicCard?            @relation("TopicCardRevisions", fields: [revisionOfId], references: [id], onDelete: SetNull)
  revisions       TopicCard[]           @relation("TopicCardRevisions")
  sourceCandidate TopicSourceCandidate? @relation(fields: [sourceCandidateId], references: [id], onDelete: SetNull)
  cases           TutorTurnCase[]

  @@index([status, subject])
  @@index([approvedAt])
  @@index([schemaVersion, status])
  @@index([contextModule, activityMode])
  @@index([revisionOfId, revision])
  @@index([sourceCandidateId])
}

model BootstrapGenerationRun {
  id                     String    @id @default(uuid())
  kind                   String
  status                 String    @default("PENDING")
  modelConfigJson        String    @default("{}")
  promptHashesJson       String    @default("{}")
  parametersJson         String    @default("{}")
  reviewPolicy           String    @default("HUMAN_ANNOTATOR_REQUIRED")
  aiDirectAuthorizedById String?
  aiDirectAuthorizedAt   DateTime?
  totalItems             Int       @default(0)
  completedItems         Int       @default(0)
  failedItems            Int       @default(0)
  failureReason          String    @default("")
  parentRunId            String?
  createdById            String?
  createdAt              DateTime  @default(now())
  startedAt              DateTime?
  completedAt            DateTime?

  parent     BootstrapGenerationRun?  @relation("BootstrapRunChain", fields: [parentRunId], references: [id], onDelete: SetNull)
  children   BootstrapGenerationRun[] @relation("BootstrapRunChain")
  createdBy  User?                    @relation("BootstrapRunCreator", fields: [createdById], references: [id], onDelete: SetNull)
  cases      TutorTurnCase[]
  candidates TutorCandidate[]

  @@index([kind, status, createdAt])
  @@index([reviewPolicy, status, createdAt])
}

model TutorTurnCase {
  id                    String   @id @default(uuid())
  topicCardId           String?
  generationRunId       String?
  revisionOfId          String?
  revision              Int      @default(1)
  phase                 Int
  triggerType           String   @default("USER_MESSAGE")
  studentMessage        String   @default("")
  historyJson           String   @default("[]")
  stageStateJson        String   @default("{}")
  visibleFactsJson      String   @default("{}")
  privateReviewSpecJson String   @default("{}")
  dataSource            String   @default("BOOTSTRAP")
  split                 String   @default("TRAIN")
  contractVersion       String   @default("tutor-language-v1")
  extractorVersion      String   @default("student-fact-extractor-v1")
  promptVersion         String   @default("tutor-language-prompt-v1")
  systemPrompt          String
  promptSha256          String
  hardCheckJson         String   @default("{}")
  status                String   @default("READY")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  topicCard           TopicCard?              @relation(fields: [topicCardId], references: [id], onDelete: SetNull)
  generationRun       BootstrapGenerationRun? @relation(fields: [generationRunId], references: [id], onDelete: SetNull)
  candidates          TutorCandidate[]
  reviewTasks         TutorReviewTask[]
  finalizedTurn       FinalizedTutorTurn?
  productionCandidate ProductionCandidate?

  @@index([status, split, phase])
  @@index([topicCardId, phase])
  @@index([revisionOfId, revision])
}

model TutorCandidate {
  id                     String   @id @default(uuid())
  caseId                 String
  generationRunId        String?
  slot                   String
  attempt                Int      @default(1)
  provider               String
  modelFamily            String
  externalModelId        String
  modelVersionTag        String
  rawOutput              String
  normalizedOutput       String
  deterministicCheckJson String   @default("{}")
  critiqueJson           String   @default("{}")
  generationParamsJson   String   @default("{}")
  promptSha256           String
  status                 String   @default("GENERATED")
  createdAt              DateTime @default(now())

  case                TutorTurnCase           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  generationRun       BootstrapGenerationRun? @relation(fields: [generationRunId], references: [id], onDelete: SetNull)
  selectedBy          TutorReviewTask[]       @relation("ReviewSelectedCandidate")
  rejectedBy          TutorReviewTask[]       @relation("ReviewRejectedCandidate")
  finalizedAsSelected FinalizedTutorTurn[]    @relation("FinalizedSelectedCandidate")
  finalizedAsRejected FinalizedTutorTurn[]    @relation("FinalizedRejectedCandidate")

  @@unique([caseId, generationRunId, slot])
  @@index([modelFamily, externalModelId])
}

model TutorReviewTask {
  id                            String    @id @default(uuid())
  caseId                        String
  type                          String
  status                        String    @default("PENDING")
  assignedToId                  String?
  leaseExpiresAt                DateTime?
  operatorId                    String?
  decision                      String    @default("")
  selectedCandidateId           String?
  preferenceRejectedCandidateId String?
  draftJson                     String    @default("{}")
  reason                        String    @default("")
  preferenceReason              String    @default("")
  warningClosureJson            String    @default("{}")
  submissionMode                String    @default("HUMAN")
  authorizedById                String?
  caseIssueJson                 String    @default("{}")
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt
  submittedAt                   DateTime?

  case                        TutorTurnCase   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  assignedTo                  User?           @relation("TutorReviewAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  operator                    User?           @relation("TutorReviewOperator", fields: [operatorId], references: [id], onDelete: SetNull)
  selectedCandidate           TutorCandidate? @relation("ReviewSelectedCandidate", fields: [selectedCandidateId], references: [id], onDelete: SetNull)
  preferenceRejectedCandidate TutorCandidate? @relation("ReviewRejectedCandidate", fields: [preferenceRejectedCandidateId], references: [id], onDelete: SetNull)

  @@unique([caseId, type])
  @@index([type, status, createdAt])
  @@index([assignedToId, status])
  @@index([submissionMode, status])
}

model FinalizedTutorTurn {
  id                            String   @id @default(uuid())
  caseId                        String   @unique
  finalOutputJson               String
  selectedCandidateId           String?
  preferenceRejectedCandidateId String?
  editMetricsJson               String   @default("{}")
  reviewerEditMetricsJson       String   @default("{}")
  draftProvenance               String   @default("LEGACY_DOUBLE_REVIEW")
  draftPreparedById             String?
  humanReviewerId               String?
  firstReviewerId               String
  secondReviewerId              String
  warningClosureJson            String   @default("{}")
  preferenceReason              String   @default("")
  trainingEligibility           String   @default("BLOCKED")
  eligibilityReasonJson         String   @default("[]")
  contentSha256                 String
  createdAt                     DateTime @default(now())

  case                        TutorTurnCase        @relation(fields: [caseId], references: [id], onDelete: Cascade)
  selectedCandidate           TutorCandidate?      @relation("FinalizedSelectedCandidate", fields: [selectedCandidateId], references: [id], onDelete: SetNull)
  preferenceRejectedCandidate TutorCandidate?      @relation("FinalizedRejectedCandidate", fields: [preferenceRejectedCandidateId], references: [id], onDelete: SetNull)
  firstReviewer               User                 @relation("FinalizedFirstReviewer", fields: [firstReviewerId], references: [id])
  secondReviewer              User                 @relation("FinalizedSecondReviewer", fields: [secondReviewerId], references: [id])
  releaseItems                DatasetReleaseItem[]

  @@index([trainingEligibility, createdAt])
  @@index([contentSha256])
}

model StateExtractionTrace {
  id                    String   @id @default(uuid())
  conversationId        String
  userMessageId         String
  stage                 Int
  extractorVersion      String
  providerSnapshot      String
  externalModelSnapshot String
  modelFamily           String
  promptVersion         String
  promptSha256          String
  sourceMessagesJson    String
  rawOutput             String
  validatedFactsJson    String   @default("[]")
  rejectedFactsJson     String   @default("[]")
  generationParamsJson  String   @default("{}")
  status                String   @default("SUCCEEDED")
  failureReason         String   @default("")
  createdAt             DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([extractorVersion, status])
}

model EvaluationArtifact {
  id        String   @id @default(uuid())
  runId     String
  kind      String
  tag       String
  sha256    String
  jsonData  String
  createdAt DateTime @default(now())

  run EvaluationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, kind, tag])
  @@index([sha256])
}

model DataLabAuditLog {
  id          String   @id @default(uuid())
  actorId     String
  action      String
  entityType  String
  entityId    String
  payloadJson String   @default("{}")
  createdAt   DateTime @default(now())

  actor User @relation("AuditActor", fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
}
