# ============================================
# Hyacintech STEM Platform - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values

# --- LLM Provider (choose one) ---

# Option 1: OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_API_BASE=https://api.openai.com/v1    # optional, default shown

# Option 2: DeepSeek
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
# DEEPSEEK_API_BASE=https://api.deepseek.com/v1  # optional, default shown

# --- General (optional) ---
# LLM_PROVIDER=openai           # explicit override, auto-detected if only one key is set
# LLM_MODEL=gpt-4o              # override model for either provider (default: gpt-4o / deepseek-chat)

# --- Database (Prisma + SQLite) ---
DATABASE_URL="file:./dev.db"

# --- Session (iron-session) ---
# 必须至少 32 个字符。生成方式: openssl rand -base64 32
SESSION_SECRET="please-change-me-to-a-random-32+char-secret"
