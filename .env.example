# ============================================
# Hyacintech STEM Platform - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# --- LLM Provider (choose one) ---

# Option 1: OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_API_BASE=https://api.openai.com/v1    # optional, default shown

# Option 2: DeepSeek
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
# DEEPSEEK_API_BASE=https://api.deepseek.com  # optional, default shown

# --- General (optional) ---
# 通过 ngrok 等 HTTPS 隧道访问开发服务器时填写域名；多个域名用逗号分隔，不要包含协议或路径。
# NEXT_ALLOWED_DEV_ORIGINS=sugar-january-recipient.ngrok-free.dev
# LLM_PROVIDER=openai           # explicit override, auto-detected if only one key is set
# LLM_MODEL=gpt-4o              # override model for either provider (default: gpt-4o / deepseek-v4-pro)
# LLM_MODEL_TAG=openai:gpt-4o    # stable registry identity; set explicitly if an endpoint/model name is mutable
# ENABLE_MODEL_DEPLOYMENT=true    # set false to emergency-disable deployment mutations
# DeepSeek V4 keeps thinking enabled. max tokens are ceilings, not pre-consumed output.
# LLM_THINKING=enabled
# LLM_REASONING_EFFORT=high
# LLM_MAX_TOKENS=16000
# LLM_TIMEOUT_MS=180000
# TUTOR_LLM_MAX_TOKENS=16000
# TUTOR_LLM_TIMEOUT_MS=180000
# STUDENT_LLM_MAX_TOKENS=10000
# STUDENT_LLM_TIMEOUT_MS=180000
# EVALUATOR_LLM_MAX_TOKENS=20000
# EVALUATOR_LLM_TIMEOUT_MS=300000

# --- Database (Prisma + SQLite) ---
DATABASE_URL="file:./dev.db"

# --- Session (iron-session) ---
# 必须至少 32 个字符。生成方式: openssl rand -base64 32
SESSION_SECRET="please-change-me-to-a-random-32+char-secret"

# --- Data Lab administrator (optional, used by npm run db:seed) ---
# ADMIN_USERNAME="data-admin"
# ADMIN_PASSWORD="change-me-strong-password"
# ADMIN_DISPLAY_NAME="数据平台主管"
