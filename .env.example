# Hyacintech STEM Platform
# Copy to .env, replace every placeholder, and never commit the resulting .env file.

# --- Required server settings ---

# SQLite URL. Relative file paths are resolved from prisma/ by Prisma.
DATABASE_URL="file:./dev.db"

# iron-session secret: at least 32 characters. Generate with: openssl rand -base64 32
SESSION_SECRET="please-change-me-to-a-random-32+char-secret"

# Configure at least one valid provider key. Do not leave a placeholder in production.
OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_API_BASE=https://api.openai.com/v1
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
# DEEPSEEK_API_BASE=https://api.deepseek.com

# --- Data Lab administrator ---
# Required by `npm run data-lab:init`; `npm run db:seed` only uses them when all three are set.
# ADMIN_USERNAME="data-admin"
# ADMIN_PASSWORD="change-me-strong-password"
# ADMIN_DISPLAY_NAME="数据平台主管"

# --- Runtime LLM overrides (optional) ---
# Provider is auto-detected when only one valid key is configured.
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# Use a stable identity when a gateway's model name can point to changing weights.
# LLM_MODEL_TAG=openai:gpt-4o
# DeepSeek V4 keeps thinking enabled. Token values are output ceilings.
# LLM_THINKING=enabled
# LLM_REASONING_EFFORT=high
# LLM_MAX_TOKENS=16000
# LLM_TIMEOUT_MS=180000
# TUTOR_LLM_MAX_TOKENS=16000
# TUTOR_LLM_TIMEOUT_MS=180000
# STUDENT_LLM_MAX_TOKENS=10000
# STUDENT_LLM_TIMEOUT_MS=180000
# EVALUATOR_LLM_MAX_TOKENS=20000
# EVALUATOR_LLM_TIMEOUT_MS=300000

# Structured state extraction can use a smaller/dedicated model.
# EXTRACTOR_LLM_PROVIDER=deepseek
# EXTRACTOR_LLM_MODEL=deepseek-v4-pro

# --- Data Lab generation and governance (optional) ---
# Keep A/B on different model families. OpenAI-compatible relays use provider=openai
# and therefore OPENAI_API_KEY / OPENAI_API_BASE.
# DATA_LAB_MODEL_A_PROVIDER=openai
# DATA_LAB_MODEL_A=Qwen3.5-35B-A3B
# DATA_LAB_MODEL_B_PROVIDER=deepseek
# DATA_LAB_MODEL_B=deepseek-v4-pro

# AI-assisted TopicCard curation and first-review drafts.
# DATA_LAB_AI_CURATOR_PROVIDER=deepseek
# DATA_LAB_AI_CURATOR_MODEL=deepseek-v4-pro

# Emergency switch: false blocks deployment mutations without changing stored state.
# ENABLE_MODEL_DEPLOYMENT=true
# Promote the current runtime prompt as the initial registered baseline when bootstrapping.
# PROMOTE_RUNTIME_PROMPT_BASELINE=false

# --- Development only (optional) ---
# HTTPS tunnel hostnames, comma-separated, without protocol or path.
# NEXT_ALLOWED_DEV_ORIGINS=sugar-january-recipient.ngrok-free.dev

# --- Script/test only (do not set on the production service) ---
# DATA_LAB_TEST_CAMPAIGN=dataset-base-v1-pilot-12
# DATA_LAB_USE_TEST_RELEASE_DIR=true
# TEST_BASE_URL=http://127.0.0.1:3000
# MODEL_TAG=candidate-model-tag
# JUDGE_API_KEY=sk-judge-key
# JUDGE_API_BASE=https://example.com/v1
# JUDGE_MODEL=judge-model-name
# JUDGE_TIMEOUT_MS=180000
# JUDGE_MAX_TOKENS=2000
# ALLOW_LEGACY_ONE_SHOT_DISTILL=false
